---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-cream-soft)] mt-20">
  <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm" style="font-family: var(--font-ui); color: var(--color-ink-soft);">
    <p>© {year} Fablewick · Free, open-source, ad-free</p>
    <div class="flex items-center gap-6">
      <a href="/about" class="hover:text-[var(--color-ink)] transition">About</a>
      <a href="https://github.com/" class="hover:text-[var(--color-ink)] transition">GitHub</a>
      <span class="opacity-60">A small light.</span>
    </div>
  </div>
</footer>
